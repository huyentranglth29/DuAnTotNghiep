# Sao chép file này thành .env ở thư mục gốc (cùng cấp package.json)
#
# Android Emulator:  http://10.0.2.2:3000
# Thiết bị thật:     http://<IP-máy-tính>:3000

API_BASE_URL=http://10.0.2.2:3000
API_TIMEOUT=15000

# Google Sign-In — cùng Web Client ID với backend GOOGLE_CLIENT_ID
# (Đã có sẵn trong src/config/google.config.js; dòng dưới dùng nếu đọc từ react-native-config)
GOOGLE_WEB_CLIENT_ID=610098112221-81itiqbuku3n1acfnq863j2r5mg572ci.apps.googleusercontent.com
